{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --ignore-scripts",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/learn",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/retention",
      "schedule": "0 3 * * *"
    }
  ]
}
