# W67 — vitest env stubs.
#
# This file is checked into the repo on purpose. It supplies fake values for
# every secret the test suite expects to read so the suite can run without
# .env.local (which contains real production keys). Anything here is harmless
# and must never reach a real backend at test time.
#
# Tests that need different values should override via beforeEach in the test
# file itself, not by editing this file.

NODE_ENV=test
APP_SECRET_KEY=test-app-secret-key-do-not-use-in-prod-aaaaaaaaaaaa
APP_PHI_KEK=dGVzdC1raGstYmFzZTY0LWZha2UtZG8tbm90LXVzZS1wcm9k
AUTH_SECRET=test-auth-secret-do-not-use-in-prod-aaaaaaaaaaaaaaaa
JWT_SECRET=test-jwt-secret-do-not-use-in-prod-aaaaaaaaaaaaaaaa
CRON_SECRET=test-cron-secret-do-not-use-in-prod-aaaaaaaaaaaaaa
APP_PASSWORD=Vitest-Stub-Cred-9!
NVIDIA_API_KEY=nvapi-test-key-not-real
