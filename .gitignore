# deps
node_modules/

# next.js
.next/
out/

# env (never commit real values)
.env
.env.local
.env.*.local

# system
.DS_Store
*.pem

# debug
npm-debug.log*

# vercel
.vercel

# Images — blanket-ignored, then explicitly re-allowed under public/ at any depth.
*.png
*.jpg
*.jpeg
!public/**/*.png
!public/**/*.jpg
!public/**/*.jpeg
!public/**/*.svg

# tsbuild incremental output
*.tsbuildinfo

# local agent/vector stores
*.rvf
*.rvf.lock
ruvector.db

# python sidecar bytecode
__pycache__/
*.pyc
sidecar/.venv/

.env*.local
