{
  "name": "mediq",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "quality:baseline": "tsx scripts/quality-harness.ts --out=src/__tests__/quality/baseline.json",
    "quality:current": "tsx scripts/quality-harness.ts --out=src/__tests__/quality/current.json --diff=src/__tests__/quality/baseline.json",
    "db:enable-citext": "node scripts/enable-citext.mjs",
    "db:setup": "node scripts/enable-citext.mjs && npx drizzle-kit push",
    "db:seed-admin": "node scripts/seed-admin.mjs",
    "setup-secrets": "node scripts/setup-secrets.mjs",
    "db:add-perf-indexes": "node scripts/add-perf-indexes.mjs",
    "db:add-source-feeds-unique": "node scripts/add-source-feeds-unique.mjs",
    "db:migrate-corpus": "node scripts/migrate-corpus-to-rivestack.mjs",
    "db:create-hnsw-index": "node scripts/create-hnsw-index.mjs",
    "scrapling:sidecar": "~/scrapling-env/bin/uvicorn sidecar.scrapling_sidecar:app --host 127.0.0.1 --port 8003",
    "scrapling:health": "curl -s http://127.0.0.1:8003/health"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.1.0",
    "@node-rs/argon2": "^2.0.2",
    "agentation": "^3.0.2",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lru-cache": "^11.0.2",
    "next": "16.2.6",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "^7.0.0",
    "unpdf": "^1.6.2",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "22.19.15",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "4.1.17",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "sanitize-html": "^2.17.4",
    "postcss": "^8.5.15",
    "esbuild": "^0.25.0",
    "@typescript-eslint/typescript-estree": {
      "minimatch": {
        "brace-expansion": "^5.0.6"
      }
    }
  }
}
