# NVIDIA NIM API key — get one free at https://build.nvidia.com
# NEVER commit real keys. Rotate immediately if exposed.
NVIDIA_API_KEY=nvapi-your-key-here

# Primary Postgres (operational tables: feeds, sessions, manager events, auth).
# Use a POOLED connection string (e.g. Neon -pooler host) for serverless.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional secondary Postgres for the RAG corpus (sources + embeddings only).
# When set, the large vector corpus is split here to free the primary DB.
# MUST be a POOLED endpoint — a direct host with a low per-role connection
# cap will fail under serverless load (Postgres 53300 too_many_connections).
# Leave unset to keep the corpus on DATABASE_URL (no behaviour change).
# RIVESTACK_DATABASE_URL=postgres://user:pass@pooled-host:5432/db?sslmode=require

# ── Scrapling sidecar (anti-bot HTML fetch for crawlers) ──────────────────────
# Master switch — when 1, crawler HTML fetches route through the Python
# sidecar (sidecar/scrapling_sidecar.py); leave unset on Vercel unless the
# sidecar is reachable on a public URL. PDFs and JSON APIs stay on safeFetch.
# SCRAPLING_GLOBAL=1
#
# Sidecar URL (default http://127.0.0.1:8003 for local dev).
# SCRAPLING_SIDECAR_URL=http://127.0.0.1:8003
#
# Optional shared secret. If set, the sidecar requires `X-Auth-Token: <token>`.
# SCRAPLING_SIDECAR_TOKEN=
#
# Set to 0 to bypass scrapling and force safeFetch path (debugging / Vercel prod
# without a sidecar host). Overrides SCRAPLING_GLOBAL.
# SCRAPLING_ENABLED=1
