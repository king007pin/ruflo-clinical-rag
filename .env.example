# ── Database ────────────────────────────────────────────────────────────────
# Neon (free): https://neon.tech  →  copy the pooled connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NVIDIA NIM (free tier) ───────────────────────────────────────────────────
# Get key at https://build.nvidia.com  →  "Get API Key"
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# ── Auth ─────────────────────────────────────────────────────────────────────
APP_PASSWORD=choose-a-strong-password
# Generate: openssl rand -hex 32
AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron security (Vercel auto-injects this on paid plans) ───────────────────
# For manual refresh: pass as ?secret=<value> query param
CRON_SECRET=another-random-secret

# ── Tinyfish (optional — enhanced web scraping, anti-bot bypass) ─────────────
# https://tinyfish.io  →  for JS-rendered pages and paywalled sites
TINYFISH_API_KEY=

# ── NCBI / PubMed (optional — increases rate limit 3→10 req/s) ──────────────
# Free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Ruflo (optional — adds a 6th swarm agent) ────────────────────────────────
RUFLO_API_URL=https://your-ruflo-host
RUFLO_API_KEY=your-ruflo-key
